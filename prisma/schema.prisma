// ================================
// PONTOFACIL - SCHEMA DO BANCO DE DADOS
// Multi-tenant com Row-Level Security
// ================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime (ex.: pooler Supabase :6543 + ?pgbouncer=true). Migrações usam directUrl.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---- EMPRESAS (TENANTS) ----
model Tenant {
  id             String   @id @default(uuid())
  razaoSocial    String
  nomeFantasia   String
  cnpj           String   @unique
  email          String
  telefone       String?
  plano          Plano    @default(BASICO)
  status         StatusTenant @default(ATIVO)

  // Canais de registro (por empresa)
  permitirTotem    Boolean @default(true)
  permitirMeuPonto Boolean @default(true)

  // Geofencing
  geofenceLat    Float?
  geofenceLng    Float?
  geofenceRaio   Int      @default(200) // metros

  // Configurações
  fotoObrigatoria Boolean @default(true)
  geofenceAtivo   Boolean @default(false)
  toleranciaMinutos Int   @default(5)
  /// Aviso/validação de "registro cedo demais" (minutos)
  trabalhoMinimoAntesSaidaMinutos Int @default(30)
  intervaloMinimoAlmocoMinutos    Int @default(30)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  usuarios       Usuario[]
  registros      RegistroPonto[]
  escalas        Escala[]
  ajustes        AjustePonto[]
  solicitacoesAjustePonto SolicitacaoAjustePonto[]
  locaisRegistro LocalRegistro[]
  comprovantesAusencia ComprovanteAusencia[]
  feriados       Feriado[]
  ferias         Ferias[]
  espelhoFechamentos EspelhoFechamento[]

  @@map("tenants")
}

// ---- LOCAIS DE REGISTRO (múltiplas cercas por empresa) ----
model LocalRegistro {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nome       String
  latitude   Float
  longitude  Float
  raioMetros Int      @default(200)
  ativo      Boolean  @default(true)
  ordem      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  usuariosVinculados Usuario[]

  @@index([tenantId])
  @@map("locais_registro")
}

enum Plano {
  BASICO      // até 10 usuários
  PROFISSIONAL // até 50 usuários
  ENTERPRISE  // ilimitado
}

enum StatusTenant {
  ATIVO
  SUSPENSO
  CANCELADO
}

// ---- USUÁRIOS ----
model Usuario {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  nome        String
  email       String
  pinHash     String   // PIN numérico hasheado (usado no totem)
  /// Senha de login web (painel / meu ponto). Se null, o login web aceita o PIN via pinHash (compatibilidade).
  senhaHash   String?
  pinEncrypted String? // PIN criptografado (reversível) para exibição por ADMIN/SUPER_ADMIN
  passwordResetToken   String?
  passwordResetExpires DateTime?
  cargo       String?
  departamento String?
  role        Role     @default(COLABORADOR)
  ativo       Boolean  @default(true)
  fotoPerfil  String?

  /// Dados de vínculo (admissão/demissão). Usado para calcular dias aplicáveis no espelho.
  dataAdmissao DateTime?
  dataDemissao DateTime?

  /// Se preenchido, o colaborador só pode registrar dentro deste local (dentre os ativos do tenant).
  localRegistroId String?
  localRegistro   LocalRegistro? @relation(fields: [localRegistroId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  registros   RegistroPonto[]
  escalas     Escala[]
  ajustesFeitos AjustePonto[] @relation("AdminAjuste")
  solicitacoesAjustePonto SolicitacaoAjustePonto[]
  solicitacoesAjusteRespondidas SolicitacaoAjustePonto[] @relation("SolicitacaoRespondidaAdmin")
  comprovantesAusencia ComprovanteAusencia[]
  comprovantesRespondidos ComprovanteAusencia[] @relation("ComprovanteRespostaAdmin")

  registrosExcluidos RegistroPonto[] @relation("RegistroPontoExcluidoPor")

  ferias Ferias[]
  espelhoFechamentos EspelhoFechamento[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([passwordResetToken])
  @@map("usuarios")
}

enum Role {
  SUPER_ADMIN
  ADMIN       // Gerente da empresa
  COLABORADOR
}

// ---- REGISTROS DE PONTO ----
model RegistroPonto {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])

  tipo        TipoPonto
  dataHora    DateTime @default(now())

  // Localização
  latitude    Float?
  longitude   Float?
  dentroGeofence Boolean?

  // Foto
  fotoUrl     String?
  fotoKey     String?  // chave no S3

  // Dispositivo
  deviceId    String?
  ipHash      String?
  userAgent   String?

  // Status
  validado    Boolean  @default(true)
  origem      OrigemPonto @default(TOTEM)

  createdAt   DateTime @default(now())

  ajuste      AjustePonto?

  // Exclusão (soft-delete) com auditoria
  deletedAt     DateTime?
  deletedById   String?
  deletedBy     Usuario? @relation("RegistroPontoExcluidoPor", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedMotivo String?

  @@index([tenantId, usuarioId])
  @@index([tenantId, dataHora])
  @@map("registros_ponto")
}

enum TipoPonto {
  ENTRADA
  SAIDA_ALMOCO
  RETORNO_ALMOCO
  SAIDA
}

enum OrigemPonto {
  TOTEM
  APP_INDIVIDUAL
  ADMIN_MANUAL
}

enum StatusSolicitacaoAjustePonto {
  PENDENTE
  ATENDIDA
  REJEITADA
}

// ---- SOLICITAÇÕES DE AJUSTE (COLABORADOR -> ADMIN/RH) ----
model SolicitacaoAjustePonto {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuarioId      String
  usuario        Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  /// Dia de referência da pendência (YYYY-MM-DD)
  dia            String
  /// Tipo faltante ou que precisa correção
  tipo           TipoPonto
  /// Sugestão do colaborador (opcional)
  dataHoraSugerida DateTime?
  justificativa  String

  status         StatusSolicitacaoAjustePonto @default(PENDENTE)
  respondidoPorId String?
  respondidoPor   Usuario? @relation("SolicitacaoRespondidaAdmin", fields: [respondidoPorId], references: [id], onDelete: SetNull)
  respondidoEm    DateTime?
  respostaAdmin   String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, usuarioId, dia])
  @@index([tenantId, status])
  @@map("solicitacoes_ajuste_ponto")
}

// ---- ESCALAS DE TRABALHO ----
model Escala {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])

  nome        String
  horaInicio  String   // "08:00"
  horaFim     String   // "17:00"
  /// Horários esperados de saída/retorno do intervalo (opcional; reforça flags no espelho)
  horaSaidaAlmoco   String?
  horaRetornoAlmoco String?
  diasSemana  Int[]    // [1,2,3,4,5] = seg a sex (ISO: seg=1 ... dom=7)

  cargaHorariaDiaria Float @default(8)
  intervaloMinutos   Int   @default(60)

  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, usuarioId])
  @@map("escalas")
}

// ---- AJUSTES DE PONTO (AUDITORIA) ----
model AjustePonto {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  registroId    String   @unique
  registro      RegistroPonto @relation(fields: [registroId], references: [id])
  adminId       String
  admin         Usuario  @relation("AdminAjuste", fields: [adminId], references: [id])

  dataHoraOriginal DateTime
  dataHoraNova     DateTime
  motivo           String
  aprovado         Boolean @default(true)

  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@map("ajustes_ponto")
}

// ---- COMPROVANTES DE AUSÊNCIA (atestado, declaração, etc.) ----
model ComprovanteAusencia {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuarioId       String
  usuario         Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  /// Período da falta (YYYY-MM-DD)
  dataReferencia  String
  dataFim         String?
  descricao       String?

  tipoArquivo     String
  arquivoKey      String?
  arquivoUrl      String?
  mimeType        String?
  nomeArquivoOriginal String?

  status          StatusComprovante @default(PENDENTE)
  observacaoAdmin String?
  respondidoPorId String?
  respondidoPor   Usuario? @relation("ComprovanteRespostaAdmin", fields: [respondidoPorId], references: [id], onDelete: SetNull)
  respondidoEm    DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status])
  @@index([usuarioId])
  @@map("comprovantes_ausencia")
}

enum StatusComprovante {
  PENDENTE
  APROVADO
  REJEITADO
}

// ---- FECHAMENTO / ACEITE DO ESPELHO MENSAL (COLABORADOR) ----
model EspelhoFechamento {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  /// Competência do fechamento (mês/ano)
  mes       Int
  ano       Int

  /// Hash do espelho (rows) no momento do aceite (garante integridade)
  espelhoHash String
  aprovadoEm  DateTime @default(now())

  /// Assinatura capturada na tela (opcional). Pode ser um dataURL "data:image/png;base64,..."
  assinaturaDataUrl String? @db.Text
  /// Vetor de traços/pontos (opcional), para re-renderizar sem armazenar imagem
  assinaturaStrokes Json?

  /// Auditoria (não armazena IP em claro)
  ipHash    String?
  userAgent String?
  deviceId  String?

  createdAt DateTime @default(now())

  @@unique([tenantId, usuarioId, mes, ano])
  @@index([tenantId, mes, ano])
  @@index([tenantId, usuarioId])
  @@map("espelho_fechamentos")
}

// ---- FERIADOS (por empresa) ----
model Feriado {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Dia do feriado no formato YYYY-MM-DD (evita problemas de fuso)
  data      String
  nome      String
  /// Se true, não há expediente/registro esperado no dia (impacta espelho/resumo).
  suspendeExpediente Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, data])
  @@index([tenantId, data])
  @@map("feriados")
}

// ---- FÉRIAS (por colaborador) ----
model Ferias {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  /// Período (YYYY-MM-DD) inclusivo
  dataInicio String
  dataFim    String
  status     StatusFerias @default(PENDENTE)
  observacao String?
  /// Retorno do gestor ao aprovar ou rejeitar solicitação
  respostaAdmin String?
  respondidoEm  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, usuarioId])
  @@index([tenantId, dataInicio, dataFim])
  @@map("ferias")
}

enum StatusFerias {
  PENDENTE
  APROVADA
  REJEITADA
  CANCELADA
}

// ---- SUPER ADMIN (separado dos tenants) ----
model SuperAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  senhaHash String
  nome      String
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  passwordResetToken   String?
  passwordResetExpires DateTime?

  @@index([passwordResetToken])
  @@map("super_admins")
}
