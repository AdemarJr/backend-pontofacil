NODE_ENV=development
PORT=3001

# --- Supabase + Prisma (obrigatório ter as duas) ---
# No painel: Project Settings → Database → Connection string → "Connect"
# Use o modo TRANSACTION (porta 6543) para DATABASE_URL e append &sslmode=require
#
# DATABASE_URL = Transaction pooler (PgBouncer) — uso no Railway / produção
# DIRECT_URL   = Session pooler na porta 5432 (host pooler) OU conexão direta db.xxx — migrações (prisma migrate)
#
# Exemplo formato pooler (usuário postgres.PROJECT_REF — copie exatamente do Supabase):
# DATABASE_URL="postgresql://postgres.xxxxx:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# DIRECT_URL="postgresql://postgres.xxxxx:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"
#
# Dev local só com Postgres direto (sem pooler): pode repetir a mesma URL nas duas.
DATABASE_URL=""
DIRECT_URL=""

JWT_SECRET=defina_uma_string_longa_e_aleatoria
JWT_REFRESH_SECRET=outra_string_longa_diferente
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3000
CORS_EXTRA_ORIGINS=

AWS_S3_ENABLED=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=pontofacil-fotos
